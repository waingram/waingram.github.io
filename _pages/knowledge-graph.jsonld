    {
      "@id": "https://waingram.github.io/#research-layer-knowledge-access",
      "@type": "DefinedTerm",
      "name": "Knowledge Access",
      "description": "Work on how machines find and retrieve research knowledge through repository interoperability, metadata standards, ETD networks, indexing, document structure extraction, and summarization."
    },
    {
      "@id": "https://waingram.github.io/#research-layer-knowledge-understanding",
      "@type": "DefinedTerm",
      "name": "Knowledge Understanding",
      "description": "Work on how machines recognize what research contributes to a goal through goal-conditioned evaluation, evaluative functions, retrieval, classification, and scientific contribution modeling."
    },
    {
      "@id": "https://waingram.github.io/#research-layer-knowledge-use",
      "@type": "DefinedTerm",
      "name": "Knowledge Use",
      "description": "Work on how machines use research knowledge to support scientific work through representation of research processes, methodological context, and workflow-like knowledge."
    },
    {
      "@id": "https://waingram.github.io/#project-goal-conditioned-evaluation",
      "@type": "ResearchProject",
      "name": "Goal-Conditioned Evaluation in Scholarly Collections",
      "description": "Dissertation research that developed a framework for evaluating research contributions relative to explicit goals, using SDG alignment as a testbed.",
