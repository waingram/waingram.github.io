    "research_program": "Studies how scientific knowledge, research workflows, and scholarly artifacts become machine-usable resources for computational discovery, reasoning, and reuse.",
    "research_question": "How can scientific knowledge, research workflows, and scholarly artifacts be represented so that they can be discovered, interpreted, and reused by intelligent systems?",
    "machine_summary": "William A. Ingram studies machine-usable scientific knowledge across three connected layers: computational access to research collections, goal-conditioned interpretation of research contributions, and representation of methods and workflow-like knowledge for AI-assisted discovery.",
    "research_layers": [
      {
        "name": "Knowledge Access",
        "question": "How do machines find and retrieve research knowledge?",
        "methods": [
          "repository interoperability",
          "metadata standards",
          "ETD networks",
          "large-scale indexing",
          "document structure extraction",
          "summarization"
        ]
      },
      {
        "name": "Knowledge Understanding",
        "question": "How do machines recognize what research contributes to a goal?",
        "methods": [
          "goal-conditioned evaluation",
          "large language models as evaluative functions",
          "classification",
          "retrieval evaluation",
          "scientific contribution modeling"
        ]
      },
      {
        "name": "Knowledge Use",
